---
import "../styles/global.css";
import { Font } from "astro:assets";
import LoadingIndicator from "astro-loading-indicator/component";

interface Props {
        title?: string;
        description?: string;
        keywords?: string;
        type?: string;
        image?: string;
        lang?: string;
        locale?: string;
}

const {
        title,
        description,
        keywords,
        type = "website",
        image,
        lang = "en",
        locale,
} = Astro.props;

const resolvedLocale = locale ?? (lang === "vi" ? "vi_VN" : "en_US");

// Default SEO strings reflect the current CV-backed profile.
const defaultTitle = "Ngọc Thưởng Đoàn | AI Engineer";
const defaultDescription =
        "Ngọc Thưởng Đoàn is an AI Engineer at Vincere, part of The Access Group, with frontend engineering experience across React, Vue, JavaScript, SEO, and AI-assisted delivery.";
const defaultKeywords =
        "Ngọc Thưởng Đoàn, Jasper Doan, AI Engineer, Vincere, The Access Group, React, Vue, JavaScript, SEO, prompt engineering, frontend engineering";

// Get the canonical URL
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteUrl = "https://thuongda.dev";

// JSON‑LD Structured Data for Person
const personSchema = {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Ngọc Thưởng Đoàn",
        "alternateName": "Jasper Doan",
        "url": siteUrl,
        "image": `${siteUrl}/social-image.jpg`,
        "email": "mailto:ngthuongdoan@gmail.com",
        "telephone": "+84941635619",
        "address": {
                "@type": "PostalAddress",
                "addressLocality": "Ho Chi Minh City",
                "addressCountry": "Vietnam",
        },
        "sameAs": [
                "https://github.com/ngthuongdoan",
                "https://www.linkedin.com/in/ngthuongdoan/",
        ],
        "jobTitle": "AI Engineer",
        "worksFor": {
                "@type": "Organization",
                "name": "Vincere, part of The Access Group",
        },
        "description": defaultDescription,
        "knowsAbout": [
                "AI Engineering",
                "Prompt Engineering",
                "Artificial Intelligence",
                "React.js",
                "Vue.js",
                "JavaScript",
                "SEO",
                "Storybook",
                "Google Analytics",
                "Google Tag Manager",
                "Frontend Engineering",
        ],
};

// JSON‑LD for Website
const websiteSchema = {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Ngọc Thưởng Đoàn - AI Engineer",
        "url": siteUrl,
        "description": defaultDescription,
        "author": {
                "@type": "Person",
                "name": "Ngọc Thưởng Đoàn",
        },
};
---

<!doctype html>
<html lang={lang}>
        <head>
                <meta charset="UTF-8" />
                <meta name="viewport" content="width=device-width, initial-scale=1" />
                <meta http-equiv="Content-Language" content={lang} />
                <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
                <meta name="generator" content={Astro.generator} />

                <!-- Primary Meta Tags -->
                <title>{title ?? defaultTitle}</title>
                <meta name="title" content={title ?? defaultTitle} />
                <meta name="description" content={description ?? defaultDescription} />
                <meta name="keywords" content={keywords ?? defaultKeywords} />
                <meta name="author" content="Ngọc Thưởng Đoàn" />
                <meta name="robots" content="index, follow" />
                <link rel="canonical" href={canonicalURL} />

                <!-- JSON‑LD Structured Data -->
                <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
                <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

                <!-- Open Graph / Facebook -->
                <meta property="og:type" content={type} />
                <meta property="og:url" content={canonicalURL} />
                <meta property="og:locale" content={resolvedLocale} />
                <meta property="og:title" content={title ?? defaultTitle} />
                <meta property="og:description" content={description ?? defaultDescription} />
                <meta property="og:image" content={`${siteUrl}/social-image.jpg`} />
                <meta property="og:site_name" content="Ngọc Thưởng Đoàn" />

                <!-- Twitter Meta Tags -->
                <meta name="twitter:card" content="summary_large_image" />
                <meta property="twitter:domain" content="thuongda.dev" />
                <meta property="twitter:url" content={canonicalURL} />
                <meta name="twitter:title" content={title ?? defaultTitle} />
                <meta name="twitter:description" content={description ?? defaultDescription} />
                <meta name="twitter:image" content={`${siteUrl}/social-image.jpg`} />

                <!-- Theme Color -->
                <meta name="theme-color" content="#131314" />

                <Font cssVariable="--font-geist" preload />
                <LoadingIndicator color="#f4f4f5" height="2px" />

        </head>
        <body class="min-h-screen bg-background font-sans text-on-background">
                <slot />
        </body>
</html>

<style>
        html,
        body {
                margin: 0;
                width: 100%;
                height: 100%;
        }
</style>
