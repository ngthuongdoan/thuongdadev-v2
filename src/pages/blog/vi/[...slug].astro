---
import { formatDate } from "../../../lib/utils";
import Prose from "../../../components/prose.astro";
import { getCollection, render } from "astro:content";
import HudArchiveLayout from "../../../components/HudArchiveLayout.astro";

export const prerender = true;

export async function getStaticPaths() {
    const articles = await getCollection("articles", ({ data }) => !data.isDraft);

    return articles.map((article) => ({
        params: {
            slug: article.data.slug
        },
        props: { article },
    }));
}

const { article } = Astro.props;

if (article === undefined) {
    return new Response("Article not found", { status: 404 });
}

const { Content } = await render(article);

const allArticles = await getCollection("articles", ({ data }) => !data.isDraft);

const relatedArticles = allArticles.filter(
    (relatedArticle) =>
        relatedArticle.data.category === article.data.category &&
        relatedArticle.id !== article.id,
);

// Generate SEO-friendly description from article
const pageTitle = `${article.data.title} | AI Engineering Notes | Ngọc Thưởng Đoàn`;
const pageDescription = article.data.snippet || `Selected reading and engineering note by Ngọc Thưởng Đoàn: ${article.data.title}.`;
const publishedDate = formatDate(article.data.pubDate);
---

<HudArchiveLayout
    title={`LOG / ${article.data.slug}`}
    kicker={`${article.data.category} transmission / ${publishedDate}`}
    commandPrompt="sys_eng@log:~$"
    commandPlaceholder="enter command (e.g. back, related, source)"
    activeSection="blog"
    pageTitle={pageTitle}
    pageDescription={pageDescription}
    lang="vi"
    langSwitcher
>
    <article class="grid gap-8 xl:grid-cols-[minmax(0,1fr)_22rem]">
        <div class="min-w-0">
            <a href="/blog/vi" class="inline-flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.16em] text-on-surface-variant transition-colors hover:text-primary">
                <span class="material-symbols-outlined text-[16px]">keyboard_backspace</span>
                Back to logs
            </a>

            <header class="mt-6 border-b border-white/10 pb-6">
                <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-secondary">
                    {article.data.category} / {article.data.readingDuration} min read
                </p>
                <h2 class="mt-3 max-w-4xl text-headline-md font-bold tracking-tight text-on-surface text-glow md:text-headline-lg">
                    {article.data.title}
                </h2>
                <p class="mt-4 max-w-3xl text-sm leading-7 text-on-surface-variant/80 sm:text-base">
                    {article.data.snippet}
                </p>
            </header>

            <div class="mt-8 max-w-3xl">
                <Prose>
                    <Content />
                </Prose>
            </div>
        </div>

        <aside class="xl:sticky xl:top-32 xl:self-start">
            <div class="hud-tech-bracket border border-outline-variant bg-surface/60 p-5 backdrop-blur-xl">
                <img
                    src={article.data.cover.src}
                    alt={article.data.coverAlt}
                    class="aspect-[4/3] w-full object-cover"
                />

                <dl class="mt-5 space-y-4 text-sm">
                    <div>
                        <dt class="text-[11px] font-semibold uppercase tracking-[0.18em] text-on-surface-variant/60">Author</dt>
                        <dd class="mt-1 text-on-surface">{article.data.author}</dd>
                    </div>
                    <div>
                        <dt class="text-[11px] font-semibold uppercase tracking-[0.18em] text-on-surface-variant/60">Published</dt>
                        <dd class="mt-1 text-on-surface">{publishedDate}</dd>
                    </div>
                    {article.data.updatedDate && (
                        <div>
                            <dt class="text-[11px] font-semibold uppercase tracking-[0.18em] text-on-surface-variant/60">Updated</dt>
                            <dd class="mt-1 text-on-surface">{formatDate(article.data.updatedDate)}</dd>
                        </div>
                    )}
                </dl>

                <a
                    href={article.data.originalLink}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="mt-6 inline-flex w-full items-center justify-center gap-2 border border-primary/40 bg-primary/10 px-4 py-3 text-xs font-semibold uppercase tracking-[0.14em] text-primary transition-colors hover:border-primary hover:bg-primary/15"
                >
                    Source Signal
                    <span class="material-symbols-outlined text-[16px]">open_in_new</span>
                </a>
            </div>

            {relatedArticles.length > 0 && (
                <div class="mt-6 border border-white/10 bg-white/[0.03] p-5">
                    <h3 class="text-[11px] font-semibold uppercase tracking-[0.18em] text-secondary">Related Logs</h3>
                    <ul class="mt-4 space-y-4">
                        {relatedArticles.map((article) => (
                            <li>
                                <a href={`/blog/vi/${article.data.slug}`} class="group block">
                                    <span class="text-sm font-semibold text-on-surface transition-colors group-hover:text-primary">{article.data.title}</span>
                                    <span class="mt-1 block text-xs text-on-surface-variant/60">{formatDate(article.data.pubDate)} / {article.data.author}</span>
                                </a>
                            </li>
                        ))}
                    </ul>
                </div>
            )}
        </aside>
    </article>
</HudArchiveLayout>
