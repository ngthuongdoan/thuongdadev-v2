---
import clsx from "clsx";
import { actions } from "astro:actions";
import HudArchiveEntry from "../../../components/HudArchiveEntry.astro";
import HudArchiveLayout from "../../../components/HudArchiveLayout.astro";

const pageTitle = "AI Engineering Notes | Ngọc Thưởng Đoàn";
const pageDescription =
	"Vietnamese engineering notes and curated readings curated by Ngọc Thưởng Đoàn, focused on AI-assisted delivery, frontend systems, software quality and modern product engineering.";

const categoriesResult = await Astro.callAction(actions.categories.getCategories, null);
const categories = categoriesResult?.data?.categories || [];

const selectedCategory = Astro.url.searchParams.get("category") || "all";

const articlesResult = await Astro.callAction(actions.categories.filterByCategory, {
	category: selectedCategory,
});

if (articlesResult?.error) {
	console.log("error", articlesResult.error);
}

const articles = (articlesResult?.data?.articles || []).sort(
	(a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const formatLogDate = (date: Date) =>
	new Intl.DateTimeFormat("en-CA", {
		year: "numeric",
		month: "2-digit",
		day: "2-digit",
	})
		.format(date)
		.replaceAll("-", ".");
---

<HudArchiveLayout
	title="/var/log/engineer_thoughts"
	kicker="Transmission listing: system logs and architectural notes"
	commandPrompt="sys_eng@core:~$"
	commandPlaceholder="enter command (e.g. search architecture)"
	activeSection="blog"
	pageTitle={pageTitle}
	pageDescription={pageDescription}
	lang="vi"
	langSwitcher
>
	<div class="mb-6 max-w-3xl space-y-3 text-sm leading-7 text-on-surface-variant/80 sm:text-base">
		<p>
			Đây là nơi tôi lưu engineering notes và curated readings về AI engineering, delivery workflows,
			software quality, và những hệ thống giúp team ship nhanh hơn.
		</p>
		<p>
			Một số bài là ghi chú của tôi, một số là trích đoạn hoặc reading notes từ tác giả khác mà tôi muốn
			giữ lại như tài liệu tham chiếu.
		</p>
	</div>

	<ul class="mb-8 flex flex-wrap items-center gap-2">
		<li>
			<a
				href="/blog/vi"
				class={clsx(
					"border px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] transition-colors",
					selectedCategory === "all"
						? "border-primary bg-primary/10 text-primary"
						: "border-outline-variant bg-white/[0.03] text-on-surface-variant hover:border-primary/50 hover:text-primary",
				)}
			>
				All Logs
			</a>
		</li>

		{categories.map((category) => (
			<li>
				<a
					href={`/blog/vi?category=${category.toLowerCase()}`}
					class={clsx(
						"border px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] transition-colors",
						selectedCategory === category.toLowerCase()
							? "border-primary bg-primary/10 text-primary"
							: "border-outline-variant bg-white/[0.03] text-on-surface-variant hover:border-primary/50 hover:text-primary",
					)}
				>
					{category}
				</a>
			</li>
		))}
	</ul>

	<div class="space-y-6">
		{articles.map((article, index) => (
			<HudArchiveEntry
				href={`/blog/vi/${article.data.slug}`}
				logId={`LOG-${String(articles.length - index).padStart(3, "0")}`}
				dateLabel={formatLogDate(article.data.pubDate)}
				title={article.data.title}
				description={article.data.snippet}
				meta={`${article.data.readingDuration} min read / ${article.data.author}`}
				tags={[
					{ label: article.data.category },
					{ label: article.data.originalLink ? "Selected reading" : "Engineering note" },
				]}
				image={article.data.cover.src}
				imageAlt={article.data.coverAlt}
			/>
		))}
	</div>
</HudArchiveLayout>
