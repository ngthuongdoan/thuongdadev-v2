---
import { getCollection } from 'astro:content';
import H1 from "../components/h1.astro";
import ProjectsSection from "../components/projects-section.astro";
import InfoLayout from "../layouts/InfoLayout.astro";

const pageTitle = "Projects | Jasper Doan - AI Engineer";
const pageDescription = "AI-augmented engineering case studies by Jasper Doan, covering autonomous delivery workflows, production architecture, and projects shipped with AI agents in the loop.";

// Fetch all projects from CMS
const allProjects = await getCollection('projects');

// Sort projects by order field (lower numbers first)
const projects = allProjects.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));

const mainProjects = projects.filter(p => p.data.category === "main");
const sideProjects = projects.filter(p => p.data.category === "side");
const openSourceProjects = projects.filter(p => p.data.category === "opensource");

const plannedProjects = [
	{
		title: "AI Code Review Assistant",
		description: "A PR analysis workflow that summarizes change risk, highlights refactor opportunities, and generates structured review output before human approval.",
		focus: "PR analysis, risk detection, refactor guidance, review automation",
	},
	{
		title: "Autonomous Delivery Dashboard",
		description: "A system for tracking agent-assisted feature delivery, code review status, testing progress, and deployment readiness across one delivery pipeline.",
		focus: "AI orchestration, delivery visibility, CI gating, execution control",
	},
	{
		title: "Observability for AI Workflows",
		description: "A case study around tracing prompt flows, task execution, and human-in-the-loop approval inside an AI-native engineering stack.",
		focus: "Prompt tracing, logs, QA checkpoints, workflow reliability",
	},
];
---

<InfoLayout title={pageTitle} description={pageDescription}>
	<div class="p-4 pb-20 sm:px-12 sm:pt-8">
		<div class="max-w-4xl space-y-5">
			<H1> Projects </H1>
			<p class="max-w-3xl text-lg leading-8 text-zinc-300 text-balance">
				Each project is framed as an AI-augmented engineering case study: architecture, delivery workflow,
				execution layers handled by agents, and the control points where engineering judgment still matters.
			</p>
		</div>

		<ProjectsSection title="Featured Projects" projects={mainProjects} />
		<ProjectsSection title="Open-source and Infrastructure" projects={openSourceProjects} className="mt-12 sm:mt-16" />
		<ProjectsSection title="Side Experiments" projects={sideProjects} className="mt-12 sm:mt-16" />

		<section class="mt-12 space-y-6 border-t border-zinc-800 pt-12 sm:mt-16 sm:pt-16">
			<div class="max-w-3xl">
				<h2 class="text-xl font-semibold text-zinc-100 sm:text-2xl">Next AI-Native Builds</h2>
				<p class="mt-3 text-base leading-7 text-zinc-400">
					Instead of hiding unfinished work, I keep the next AI-native systems visible. These are the builds I want to turn
					into deeper case studies around autonomous delivery and engineering leverage.
				</p>
			</div>

			<div class="grid gap-6 xl:grid-cols-3">
				{plannedProjects.map((project) => (
					<article class="rounded-3xl border border-zinc-800 bg-zinc-950/35 p-6">
						<p class="text-xs uppercase tracking-[0.24em] text-zinc-500">Roadmap</p>
						<h3 class="mt-3 text-xl text-zinc-100">{project.title}</h3>
						<p class="mt-3 text-sm leading-7 text-zinc-400">{project.description}</p>
						<p class="mt-4 text-sm text-zinc-300">{project.focus}</p>
					</article>
				))}
			</div>
		</section>
	</div>
</InfoLayout>
