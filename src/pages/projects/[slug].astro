---
import { getCollection, render } from "astro:content";
import Prose from "../../components/prose.astro";
import HudArchiveLayout from "../../components/HudArchiveLayout.astro";

export const prerender = true;

export async function getStaticPaths() {
    const projects = await getCollection("projects");

    return projects.map((project) => ({
        params: { slug: project.id },
        props: { project },
    }));
}

const { project } = Astro.props;

if (project === undefined) {
    return new Response("Project not found", { status: 404 });
}

const { Content } = await render(project);
const pageTitle = `${project.data.title} | Project Details | Ngọc Thưởng Đoàn`;
const pageDescription = project.data.description;
const statusLabel = project.data.status.replace("-", " ");
---

<HudArchiveLayout
    title={`DOSSIER / ${project.id}`}
    kicker={`${project.data.category} mission / ${project.data.period}`}
    commandPrompt="mission_ctl@dossier:~$"
    commandPlaceholder="enter command (e.g. archive, stack, links)"
    activeSection="projects"
    pageTitle={pageTitle}
    pageDescription={pageDescription}
>
    <article class="grid gap-8 xl:grid-cols-[minmax(0,1fr)_24rem]">
        <div class="min-w-0">
            <a href="/projects" class="inline-flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.16em] text-on-surface-variant transition-colors hover:text-primary">
                <span class="material-symbols-outlined text-[16px]">keyboard_backspace</span>
                Back to project archives
            </a>

            <header class="mt-6 border-b border-white/10 pb-6">
                <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-secondary">
                    {project.data.role} / {statusLabel}
                </p>
                <h2 class="mt-3 max-w-4xl text-headline-md font-bold tracking-tight text-on-surface text-glow md:text-headline-lg">
                    {project.data.title}
                </h2>
                <p class="mt-4 max-w-3xl text-sm leading-7 text-on-surface-variant/80 sm:text-base">
                    {project.data.description}
                </p>

                {project.data.links.length > 0 && (
                    <div class="mt-6 flex flex-wrap gap-3">
                        {project.data.links.map((link) => (
                            <a
                                href={link.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-flex items-center gap-2 border border-primary/40 bg-primary/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] text-primary transition-colors hover:border-primary hover:bg-primary/15"
                            >
                                {link.label}
                                <span class="material-symbols-outlined text-[15px]">open_in_new</span>
                            </a>
                        ))}
                    </div>
                )}
            </header>

            <div class="mt-8 max-w-3xl">
                <Prose>
                    <Content />
                </Prose>
            </div>
        </div>

        <aside class="xl:sticky xl:top-32 xl:self-start">
            <div class="hud-tech-bracket border border-outline-variant bg-surface/60 p-5 backdrop-blur-xl">
                <img
                    src={project.data.image}
                    alt={project.data.title}
                    class="aspect-[4/3] w-full object-cover"
                />

                <dl class="mt-5 space-y-4 text-sm">
                    <div>
                        <dt class="text-[11px] font-semibold uppercase tracking-[0.18em] text-on-surface-variant/60">Role</dt>
                        <dd class="mt-1 text-on-surface">{project.data.role}</dd>
                    </div>
                    <div>
                        <dt class="text-[11px] font-semibold uppercase tracking-[0.18em] text-on-surface-variant/60">Period</dt>
                        <dd class="mt-1 text-on-surface">{project.data.period}</dd>
                    </div>
                    <div>
                        <dt class="text-[11px] font-semibold uppercase tracking-[0.18em] text-on-surface-variant/60">Status</dt>
                        <dd class="mt-1 capitalize text-on-surface">{statusLabel}</dd>
                    </div>
                </dl>

                {project.data.stack.length > 0 && (
                    <div class="mt-6 border-t border-white/10 pt-5">
                        <h3 class="text-[11px] font-semibold uppercase tracking-[0.18em] text-secondary">Stack</h3>
                        <ul class="mt-3 flex flex-wrap gap-2">
                            {project.data.stack.map((item) => (
                                <li class="border border-outline-variant bg-white/[0.03] px-3 py-1 text-xs text-on-surface-variant">{item}</li>
                            ))}
                        </ul>
                    </div>
                )}
            </div>

            {project.data.metrics.length > 0 && (
                <div class="mt-6 border border-white/10 bg-white/[0.03] p-5">
                    <h3 class="text-[11px] font-semibold uppercase tracking-[0.18em] text-secondary">Signals</h3>
                    <ul class="mt-4 space-y-3 text-sm leading-6 text-on-surface-variant">
                        {project.data.metrics.map((metric) => (
                            <li class="border-l border-primary/40 pl-3">{metric}</li>
                        ))}
                    </ul>
                </div>
            )}

            {project.data.highlights.length > 0 && (
                <div class="mt-6 border border-white/10 bg-white/[0.03] p-5">
                    <h3 class="text-[11px] font-semibold uppercase tracking-[0.18em] text-secondary">Highlights</h3>
                    <ul class="mt-4 space-y-3 text-sm leading-6 text-on-surface-variant">
                        {project.data.highlights.map((item) => (
                            <li class="border-l border-secondary/40 pl-3">{item}</li>
                        ))}
                    </ul>
                </div>
            )}
        </aside>
    </article>
</HudArchiveLayout>
