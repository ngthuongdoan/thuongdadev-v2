---
import H1 from "../components/h1.astro";
import InfoLayout from "../layouts/InfoLayout.astro";

const pageTitle = "About Ngọc Thưởng Đoàn | AI Engineer";
const pageDescription =
        "Learn more about Ngọc Thưởng Đoàn, an AI Engineer at Vincere with 5 years of frontend experience across React, Vue, JavaScript, SEO, and AI-assisted delivery.";

const strengths = [
        {
                title: "Frontend Systems",
                items: [
                        "React.js and Vue.js application development",
                        "JavaScript ecosystem and responsive user interfaces",
                        "Component libraries with Storybook",
                ],
        },
        {
                title: "AI and Prompt Engineering",
                items: [
                        "Prompt Engineering",
                        "Artificial Intelligence workflows",
                        "Devin-assisted engineering execution",
                ],
        },
        {
                title: "Growth and Analytics",
                items: [
                        "SEO best practices for discoverable web products",
                        "Google Analytics, Google Tag Manager, and Google Ads",
                        "Pubmatic and MGID integrations",
                ],
        },
];

const workflow = [
        "Translate product goals into responsive frontend interfaces",
        "Build reusable components and UI systems around React and Vue",
        "Integrate analytics, advertising, and SEO requirements into implementation",
        "Use AI and prompt engineering to accelerate delivery while reviewing quality",
        "Work inside agile scrum teams with a focus on continuous improvement",
];

const experience = [
        "Artificial Intelligence Engineer at Vincere, part of The Access Group - March 2026 to present",
        "Software Engineer at Vincere - November 2024 to present",
        "Prompt Engineer at Vincere - July 2025 to April 2026",
        "Frontend Engineer at CBTW APAC - March 2024 to October 2024",
        "Frontend Engineer at Infotrack Vietnam - September 2023 to March 2024",
        "Frontend Developer at Hello Health Group - June 2022 to August 2023",
        "Front End Lead and Frontend Web Developer at Appcore - September 2021 to June 2022",
        "Frontend Web Developer at Techbase Vietnam and Can Tho University - May 2020 to September 2021",
];

const credentials = [
        "Current role: AI Engineer at Vincere, part of The Access Group",
        "Education: Bachelor of Engineering in Computer Software Engineering, Can Tho University, June 2017 to June 2021",
        "Languages: Vietnamese native or bilingual, English professional working, Spanish limited working",
        "Certifications: Networking Academy Learn-A-Thon 2021, Building a High-performance Team, Learn HTML5, React Basic, Advanced React",
        "Based in Ho Chi Minh City, Vietnam",
];
---

<InfoLayout title={pageTitle} description={pageDescription}>
        <div class="flex flex-col gap-16 p-4 pb-20 sm:px-12 sm:pt-8">
                <section class="max-w-4xl space-y-6">
                        <H1> About Ngọc Thưởng Đoàn </H1>

                        <p class="text-xl leading-9 xl:text-2xl text-zinc-300 text-balance">
                                I am an AI Engineer at Vincere, part of The Access Group.
                        </p>

                        <p class="max-w-3xl text-lg leading-8 text-zinc-400 text-balance">
                                My background is frontend development, with 5 years of experience creating responsive,
                                high-performance user interfaces across React.js, Vue.js, and the JavaScript ecosystem.
                                I also bring SEO, analytics integration, prompt engineering, and AI-assisted workflows into
                                the way I build and ship products.
                        </p>
                </section>

                <section class="grid gap-6 xl:grid-cols-[minmax(0,1.2fr)_minmax(0,0.8fr)]">
                        <div class="space-y-4">
                                <h2 class="text-sm uppercase tracking-[0.28em] text-zinc-500">How I Work</h2>
                                <ul class="space-y-3 text-base leading-7 text-zinc-300">
                                        {workflow.map((item) => <li>{item}</li>)}
                                </ul>
                        </div>

                        <div class="rounded-3xl border border-zinc-800 bg-zinc-950/40 p-6">
                                <h2 class="text-sm uppercase tracking-[0.28em] text-zinc-500">What I Focus On</h2>
                                <ul class="mt-4 space-y-3 text-sm leading-7 text-zinc-300">
                                        <li>AI and prompt engineering</li>
                                        <li>React and Vue frontend systems</li>
                                        <li>Responsive, intuitive user interfaces</li>
                                        <li>SEO and website visibility</li>
                                        <li>Analytics and advertising integrations</li>
                                </ul>
                        </div>
                </section>

                <section class="space-y-6">
                        <h2 class="text-sm uppercase tracking-[0.28em] text-zinc-500">Skills and Tools</h2>
                        <div class="grid gap-6 lg:grid-cols-3">
                                {strengths.map((group) => (
                                        <div class="rounded-3xl border border-zinc-800 bg-zinc-950/35 p-6">
                                                <h3 class="text-lg text-zinc-100">{group.title}</h3>
                                                <ul class="mt-4 space-y-3 text-sm leading-7 text-zinc-400">
                                                        {group.items.map((item) => <li>{item}</li>)}
                                                </ul>
                                        </div>
                                ))}
                        </div>
                </section>

                <section class="space-y-6">
                        <h2 class="text-sm uppercase tracking-[0.28em] text-zinc-500">Experience Log</h2>
                        <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_minmax(0,1fr)]">
                                <div class="rounded-3xl border border-zinc-800 bg-zinc-950/35 p-6">
                                        <p class="text-base leading-7 text-zinc-300">
                                                The CV shows a steady path from frontend web development into AI engineering:
                                                frontend foundations first, then prompt engineering and AI work inside Vincere.
                                        </p>
                                </div>
                                <div class="rounded-3xl border border-zinc-800 bg-zinc-950/35 p-6">
                                        <ul class="space-y-3 text-sm leading-7 text-zinc-300">
                                                {experience.map((item) => <li>{item}</li>)}
                                        </ul>
                                </div>
                        </div>
                </section>

                <section class="space-y-5">
                        <h2 class="text-sm uppercase tracking-[0.28em] text-zinc-500">Presence and Credentials</h2>
                        <ul class="space-y-3 text-base leading-7 text-zinc-300">
                                {credentials.map((item) => <li>{item}</li>)}
                        </ul>
                </section>
        </div>
</InfoLayout>
