---
import { getCollection } from "astro:content";
import HomeAbout from "../components/home/HomeAbout.astro";
import HomeBackground from "../components/home/HomeBackground.astro";
import HomeHero from "../components/home/HomeHero.astro";
import HomeHudFooter from "../components/home/HomeHudFooter.astro";
import HomeHudHeader from "../components/home/HomeHudHeader.astro";
import HomeHudScrollOut from "../components/home/HomeHudScrollOut.astro";
import HomeHudStatus from "../components/home/HomeHudStatus.astro";
import HomeProjects from "../components/home/HomeProjects.astro";
import HomeTimeline from "../components/home/HomeTimeline.astro";
import RootLayout from "../layouts/RootLayout.astro";

const pageTitle = "Mission Control | Ngọc Thưởng Đoàn";
const pageDescription =
	"Ngọc Thưởng Đoàn's cinematic portfolio mission control for AI engineering at Vincere, frontend systems, React, Vue, JavaScript, SEO, and AI-assisted delivery.";

const projects = (await getCollection("projects")).sort(
	(a, b) => (a.data.order ?? 0) - (b.data.order ?? 0),
);
---

<RootLayout title={pageTitle} description={pageDescription}>
	<HomeBackground />
	<HomeHudHeader />
	<HomeHudStatus />
	<HomeHudScrollOut />

	<main class="relative z-10 flex flex-col justify-center px-5 pb-24 pt-32 md:px-16">
		<HomeHero />
		<HomeTimeline />
		<HomeProjects projects={projects} />
		<HomeAbout />
	</main>

	<HomeHudFooter />
</RootLayout>
