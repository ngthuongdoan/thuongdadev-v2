---
import H1 from "../components/h1.astro";
import Link from "../components/link.astro";
import Navigation from "../components/navigation.astro";
import RootLayout from "../layouts/RootLayout.astro";
import AvailableForWork from "../components/available.astro";
import WarpBackground from "../components/warp-background.tsx";

const pageTitle = "Jasper Doan | AI Engineer";
const pageDescription = "AI Engineer building and shipping production systems with AI agents, structured delivery workflows, and human-in-the-loop quality control.";

const proofPoints = [
	"AI-agent workflows for implementation, refactoring, and documentation",
	"Human-in-the-loop architecture review, testing, and delivery control",
	"Production systems shipped with high velocity and maintainable code quality",
];
---

<RootLayout title={pageTitle} description={pageDescription}>
	<main>
		<div class="relative flex items-center justify-center w-full group min-h-dvh">
			<div class="absolute w-full h-dvh -z-10 bg-[radial-gradient(120%_90%_at_80%_10%,#52525b_0%,#27272a_35%,#09090b_72%)]" />
				<div class="absolute w-full h-dvh -z-10">
					<WarpBackground
						color1="#09090b"
						color2="#27272a"
						color3="#52525b"
						speed={0.6}
						swirl={0.5}
						swirlIterations={10}
						shapeScale={0.3}
						class="block"
					/>
				</div>
			<div class="absolute z-10 flex flex-col justify-between w-full p-4 sm:p-8 h-dvh">
				<div>
					<p class="mb-4 text-sm uppercase tracking-[0.3em] text-zinc-400">AI Engineer</p>
					<H1 size="large"> Jasper <br /> Doan </H1>
					<div class="max-w-2xl mt-6 space-y-5">
						<p class="text-lg leading-8 text-zinc-200 sm:text-xl sm:leading-9 text-balance">
							Building and shipping with AI agents.
						</p>

						<p class="max-w-2xl text-base leading-7 text-zinc-400 sm:text-lg text-balance">
							I design, architect, and ship production systems using AI agents such as Codex, Devin, and Copilot
							to accelerate delivery while maintaining architectural control, code quality, and long-term scalability.
						</p>
					</div>
				</div>

				<div class="space-y-6">
					<ul class="grid max-w-4xl gap-3 text-sm sm:grid-cols-3 sm:text-base">
						{proofPoints.map((item) => (
							<li class="border rounded-full border-zinc-700/70 bg-zinc-900/35 px-4 py-3 text-zinc-200 backdrop-blur-sm">
								{item}
							</li>
						))}
					</ul>

					<AvailableForWork className="py-4" />
					<div class="flex items-center justify-between mb-2 sm:mb-4">
						<div class="flex items-center gap-4">
							<Link href="/contact">Book a call</Link>
							<Link href="/projects" variant="secondary">View selected work</Link>
						</div>

						<Navigation />
					</div>
				</div>
			</div>
		</div>
	</main>
</RootLayout>
