---
import HomeIcon from "./HomeIcon.astro";
import HudFrame from "./HudFrame.astro";
---

<section class="section-about mx-auto mb-24 w-full max-w-4xl">
	<HudFrame class="overflow-hidden border border-primary/20 bg-surface/20 p-10 backdrop-blur-2xl md:p-16">
		<div class="absolute -right-40 -top-40 h-80 w-80 rounded-full bg-primary/10 blur-[100px]" aria-hidden="true"></div>
		<div class="mb-8 flex items-center gap-4 text-label-caps font-semibold uppercase tracking-[0.2em] text-primary/70">
			<HomeIcon name="person" />
			<span>OPERATOR_BIO</span>
		</div>

		<div class="grid grid-cols-1 items-center gap-12 md:grid-cols-5">
			<div class="md:col-span-3">
				<h2 class="mb-6 text-3xl font-bold leading-tight text-on-surface md:text-4xl">
					Building AI-assisted interfaces from a strong frontend foundation.
				</h2>
				<p class="mb-8 text-on-surface-variant/80">
					I am an AI Engineer at Vincere, part of The Access Group, with 6 years of frontend experience across React, Vue, JavaScript, component libraries, analytics integrations, SEO, and agile product delivery.
				</p>
				<div class="flex flex-wrap gap-4">
					<a class="inline-flex items-center gap-2 border border-white/10 bg-white/5 px-6 py-3 text-xs font-semibold uppercase tracking-[0.18em] transition-colors hover:border-primary hover:text-primary" href="/contact">
						<HomeIcon name="mail" class="text-[14px]" />
						<span>TRANSMIT</span>
					</a>
					<a class="inline-flex items-center gap-2 border border-white/10 bg-white/5 px-6 py-3 text-xs font-semibold uppercase tracking-[0.18em] transition-colors hover:border-primary hover:text-primary" href="https://www.linkedin.com/in/ngthuongdoan/" target="_blank" rel="noopener noreferrer">
						<svg class="h-3.5 w-3.5 fill-current" viewBox="0 0 24 24" aria-hidden="true">
							<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"></path>
						</svg>
						<span>NETWORK</span>
					</a>
				</div>
			</div>

			<div class="flex justify-center md:col-span-2">
				<div class="relative h-48 w-48 rounded-full border-4 border-surface-container bg-surface p-2">
					<div class="flex h-full w-full items-center justify-center overflow-hidden rounded-full border border-white/10 bg-surface-high">
						<HomeIcon name="face" class="text-[64px] text-primary/40" />
					</div>
					<div class="absolute inset-0 scale-110 animate-ping rounded-full border border-primary/50 opacity-20" aria-hidden="true"></div>
				</div>
			</div>
		</div>
	</HudFrame>
</section>
