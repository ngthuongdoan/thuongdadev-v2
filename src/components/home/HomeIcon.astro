---
type IconName =
	| "alternate-email"
	| "arrow-forward"
	| "code"
	| "dashboard"
	| "face"
	| "mail"
	| "orbit"
	| "person"
	| "rocket-launch"
	| "terminal";

interface Props {
	name: IconName;
	class?: string;
}

const { name, class: className = "" } = Astro.props;

const iconPaths: Record<IconName, string> = {
	"alternate-email": '<circle cx="12" cy="12" r="8.5"/><path d="M15.5 8.8v4.1a2.1 2.1 0 0 0 3.1 1.8"/><circle cx="12" cy="12" r="3.2"/>',
	"arrow-forward": '<path d="M5 12h14"/><path d="m13 6 6 6-6 6"/>',
	code: '<path d="m8 9-3 3 3 3"/><path d="m16 9 3 3-3 3"/><path d="m14 5-4 14"/>',
	dashboard: '<rect x="4" y="5" width="6" height="6" rx="1.5"/><rect x="14" y="5" width="6" height="6" rx="1.5"/><rect x="4" y="15" width="6" height="4" rx="1.5"/><rect x="14" y="15" width="6" height="4" rx="1.5"/>',
	face: '<circle cx="12" cy="12" r="8.5"/><path d="M8.6 10h.01"/><path d="M15.4 10h.01"/><path d="M8.8 14.2c1.8 1.7 4.6 1.7 6.4 0"/>',
	mail: '<rect x="4" y="6" width="16" height="12" rx="2"/><path d="m5 8 7 5 7-5"/>',
	orbit: '<circle cx="12" cy="12" r="2.2"/><ellipse cx="12" cy="12" rx="9" ry="4.2" transform="rotate(-25 12 12)"/><ellipse cx="12" cy="12" rx="9" ry="4.2" transform="rotate(25 12 12)"/>',
	person: '<circle cx="12" cy="8" r="3"/><path d="M5.5 19a6.5 6.5 0 0 1 13 0"/>',
	"rocket-launch": '<path d="M13.5 5.2c2.3-1.1 4.2-1.2 5.3-.1 1.1 1.1 1 3-.1 5.3L12 17l-5-5 6.5-6.8Z"/><path d="m8.5 15.5-2.7 2.7"/><path d="M14.8 5.8 18 9"/><path d="M7 12H4l2.2-3.2"/><path d="M12 17v3l3.2-2.2"/>',
	terminal: '<path d="m5 7 5 5-5 5"/><path d="M12 17h7"/>',
};
---

<svg
	class:list={["inline-block h-[1em] w-[1em] shrink-0 align-[-0.125em]", className]}
	viewBox="0 0 24 24"
	fill="none"
	stroke="currentColor"
	stroke-linecap="round"
	stroke-linejoin="round"
	stroke-width="1.8"
	aria-hidden="true"
	set:html={iconPaths[name]}
/>
