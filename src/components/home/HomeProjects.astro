---
import type { CollectionEntry } from "astro:content";
import HomeIcon from "./HomeIcon.astro";
import HudFrame from "./HudFrame.astro";

interface Props {
	projects: CollectionEntry<"projects">[];
}

const { projects } = Astro.props;
const featuredProjects = projects.slice(0, 2);
---

<section class="section-projects mx-auto mb-48 w-full max-w-6xl">
	<div class="mb-12 flex items-center justify-center gap-4 text-label-caps font-semibold uppercase tracking-[0.2em] text-secondary/70">
		<HomeIcon name="dashboard" />
		<span>PROJECT_PREVIEW</span>
		<div class="ml-4 hidden h-px flex-1 bg-white/10 md:block"></div>
	</div>

	<div class="mb-12 grid grid-cols-1 gap-6 md:grid-cols-2">
		{featuredProjects.map((project, index) => (
			<a href={`/projects/${project.id}`} class={`project-card group block overflow-hidden border border-white/10 bg-surface/30 backdrop-blur-xl ${index === 1 ? "md:mt-12" : ""}`}>
				<div class="relative h-64 overflow-hidden bg-surface-high">
					<div class="absolute inset-0 z-10 bg-gradient-to-t from-background to-transparent opacity-60"></div>
					<img
						src={project.data.thumbnail || project.data.image}
						alt={project.data.title}
						class="h-full w-full object-cover opacity-70 saturate-[1.15] transition-transform duration-700 group-hover:scale-105"
					/>
				</div>
				<HudFrame class="p-8">
					<div class="mb-3 text-label-caps font-semibold uppercase tracking-[0.18em] text-secondary/80">{project.data.status.replace("-", " ")}</div>
					<h2 class={`mb-3 text-2xl font-semibold text-primary`}>{project.data.title}</h2>
					<p class="mb-6 text-on-surface-variant/80">{project.data.description}</p>
					<ul class="flex flex-wrap gap-3">
						{project.data.stack.slice(0, 3).map((item) => (
							<li class="border border-white/10 bg-white/5 px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] text-secondary">{item}</li>
						))}
					</ul>
				</HudFrame>
			</a>
		))}
	</div>

	<div class="project-cta flex justify-center">
		<a
			class="group relative inline-flex overflow-hidden border border-secondary/30 bg-transparent px-10 py-5  font-semibold uppercase tracking-[0.18em] text-secondary transition-all duration-300 hover:border-secondary hover:bg-secondary/10"
			href="/projects"
		>
			ACCESS ALL PROJECTS
			<HomeIcon name="arrow-forward" class="relative z-10 ml-3 text-[16px] transition-transform group-hover:translate-x-1" />
		</a>
	</div>
</section>
