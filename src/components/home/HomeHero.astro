---
import HomeIcon from "./HomeIcon.astro";
---

<section id="mission" data-home-hero class="section-hero relative left-1/2 -mt-32 mb-32 flex min-h-[calc(80vh+8rem)] w-screen -translate-x-1/2 flex-col items-center justify-center overflow-hidden pt-32 text-center">
	<div class="home-hero-media absolute inset-0 -z-10" aria-hidden="true"></div>
	<div class="relative z-10 mx-auto flex max-w-5xl flex-col items-center px-5 md:px-16">
		<div class="mb-6 inline-flex items-center gap-3 rounded-full border border-white/10 bg-surface/30 px-4 py-2 text-label-caps font-semibold uppercase tracking-[0.16em] text-primary backdrop-blur-sm">
			<span class="h-2 w-2 animate-pulse rounded-full bg-primary"></span>
			<span>CONNECTION ESTABLISHED</span>
		</div>

		<h1 class="mb-8 inline-block max-w-full bg-gradient-to-b from-white to-surface-variant bg-clip-text text-[clamp(2.25rem,11.5vw,5.5rem)] font-extrabold uppercase leading-[0.96] tracking-normal text-transparent drop-shadow-[0_0_30px_rgba(208,188,255,0.3)] md:text-[6rem]">
			ENGINEERING <br /> THE VOID
		</h1>

		<p class="mb-12 max-w-2xl text-body-lg leading-8 text-on-surface-variant/90 drop-shadow-md">
			AI Engineer at Vincere, part of The Access Group, building high-performance frontend systems with React, Vue, JavaScript, SEO, and AI-assisted delivery workflows.
		</p>

		<div class="flex flex-col items-center gap-4 sm:flex-row sm:gap-8">
			<a
				class="group relative overflow-hidden border border-primary/50 bg-surface/20 px-10 py-5 text-label-caps font-semibold uppercase tracking-[0.18em] text-primary backdrop-blur-md transition-all duration-300 hover:border-primary hover:bg-primary/20 hover:shadow-[0_0_20px_rgba(208,188,255,0.4)]"
				href="/projects"
			>
				<span class="relative z-10">INITIALIZE SEQUENCE</span>
				<span class="absolute inset-0 translate-y-full bg-primary/10 transition-transform duration-300 ease-out group-hover:translate-y-0" aria-hidden="true"></span>
			</a>

			<a
				class="inline-flex items-center gap-2 px-8 py-5 text-label-caps font-semibold uppercase tracking-[0.18em] text-on-surface-variant transition-colors hover:text-primary"
				href="/contact"
			>
				<HomeIcon name="alternate-email" />
				<span>TRANSMIT</span>
			</a>
		</div>
	</div>
</section>

<style>
	.home-hero-media {
		background:
			radial-gradient(circle at center, rgb(19 19 20 / 0.18) 0%, rgb(14 14 15 / 0.76) 72%),
			linear-gradient(180deg, rgb(10 10 11 / 0.28), rgb(10 10 11 / 0.9)),
			image-set(url("/images/home.webp") type("image/webp"), url("/images/home.png") type("image/png")) center 18% / cover no-repeat;
	}
</style>
