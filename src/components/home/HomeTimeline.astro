---
import HudFrame from "./HudFrame.astro";

const entries = [
	{
		period: "Mar 2026 - Present",
		title: "Artificial Intelligence Engineer",
		subtitle: "Vincere, part of The Access Group",
		body: "Currently working as an AI Engineer after moving through prompt engineering and software engineering roles inside Vincere.",
	},
	{
		period: "Nov 2024 - Present",
		title: "Software Engineer at Vincere",
		subtitle: "The Access Group",
		body: "Contributing software engineering work in Ho Chi Minh City, with a transition into prompt engineering from July 2025 to April 2026.",
	},
	{
		period: "Mar 2024 - Oct 2024",
		title: "Frontend Engineer",
		subtitle: "CBTW APAC",
		body: "Continued frontend engineering work as Positive Thinking Company, OneAston, Versett, Otofacto, Alispharm, and SteepConsult united under the CBTW brand.",
	},
	{
		period: "Sep 2023 - Mar 2024",
		title: "Frontend Engineer",
		subtitle: "Infotrack Vietnam",
		body: "Delivered frontend engineering work in Vietnam before joining the broader CBTW APAC team.",
	},
	{
		period: "Jun 2022 - Aug 2023",
		title: "Frontend Developer",
		subtitle: "Hello Health Group",
		body: "Built high-performance websites and components, including Storybook component libraries and integrations with Google Analytics, Google Tag Manager, Google Ads, Pubmatic, and MGID.",
	},
	{
		period: "Sep 2021 - Jun 2022",
		title: "Frontend Lead and Developer",
		subtitle: "Appcore",
		body: "Led frontend work in Can Tho with a major focus on the React ecosystem.",
	},
	{
		period: "May 2020 - Sep 2021",
		title: "Frontend Developer",
		subtitle: "Can Tho University and Techbase Vietnam",
		body: "Built websites with MEVN stack foundations and Java Spring, then continued frontend web development at Techbase Vietnam.",
	},
];
---

<section class="section-timeline relative left-1/2 mb-48 w-screen -translate-x-1/2 px-5 md:px-16" aria-labelledby="experience-log-title">
	<div class="mx-auto mb-10 flex w-full max-w-[88rem] flex-col gap-5 md:mb-14 md:flex-row md:items-end md:justify-between">
		<div>
			<div class="mb-4 flex items-center gap-4 text-label-caps font-semibold uppercase tracking-[0.2em] text-secondary/70">
				<span class="material-symbols-outlined" aria-hidden="true">orbit</span>
				<span>EXPERIENCE_LOG</span>
				<div class="hidden h-px w-28 bg-white/10 md:block"></div>
			</div>
			<h2 id="experience-log-title" class="max-w-2xl text-headline-md text-on-surface md:text-headline-lg">
				Travel through the verified work timeline.
			</h2>
		</div>
		<p class="max-w-md text-sm leading-6 text-on-surface-variant/75 md:text-right">
			Scroll sideways through the orbital rail. Each marker is grounded in the current CV.
		</p>
	</div>

	<div class="timeline-shell relative overflow-hidden border-y border-secondary/15 bg-obsidian/50 shadow-hud backdrop-blur-2xl md:rounded-panel md:border-x">
		<div class="pointer-events-none absolute inset-0 cosmic-grid opacity-[0.18]" aria-hidden="true"></div>
		<div class="pointer-events-none absolute inset-x-0 top-0 h-24 bg-gradient-to-b from-primary/10 to-transparent" aria-hidden="true"></div>
		<div class="pointer-events-none absolute -left-24 top-1/2 h-64 w-64 -translate-y-1/2 rounded-full bg-accent/20 blur-3xl" aria-hidden="true"></div>
		<div class="pointer-events-none absolute -right-20 bottom-0 h-56 w-56 rounded-full bg-secondary-container/20 blur-3xl" aria-hidden="true"></div>

		<div class="timeline-viewport relative" data-timeline-viewport>
			<div class="timeline-station" data-timeline-ship aria-hidden="true">
				<div class="endurance-ring">
					<span class="endurance-hub"></span>
					<span class="endurance-dock endurance-dock-top"></span>
					<span class="endurance-dock endurance-dock-right"></span>
					<span class="endurance-dock endurance-dock-bottom"></span>
					<span class="endurance-dock endurance-dock-left"></span>
				</div>
			</div>

			<div
				class="timeline-scroll relative z-10 flex snap-x snap-mandatory gap-6 overflow-x-auto px-6 pb-10 pt-24 md:gap-8 md:px-16 md:pb-12 md:pt-28 lg:px-24"
				data-timeline-scroll
				tabindex="0"
				aria-label="Scrollable work timeline"
			>
				<div class="timeline-track" aria-hidden="true">
					<span data-timeline-progress></span>
				</div>

				{entries.map((entry, index) => (
					<article
						id={`timeline-mission-${index + 1}`}
						class="timeline-card relative min-w-[min(84vw,26rem)] snap-center pt-10 md:min-w-[42rem] lg:min-w-[46rem]"
						data-timeline-card
					>
						<a
							class="timeline-node"
							href={`#timeline-mission-${index + 1}`}
							data-timeline-anchor
							aria-label={`Scroll timeline to ${entry.title}`}
						>
							<span>{String(index + 1).padStart(2, "0")}</span>
						</a>
						<HudFrame class="h-full border border-white/10 bg-surface/35 p-6 backdrop-blur-xl transition-all duration-500 hover:-translate-y-1 hover:border-primary/50 hover:bg-surface-container/45 md:p-8">
							<div class="mb-4 flex items-center justify-between gap-4">
								<div class="text-label-caps font-semibold uppercase tracking-[0.18em] text-primary">{entry.period}</div>
								<div class="h-px flex-1 bg-gradient-to-r from-primary/50 to-transparent"></div>
							</div>
							<h3 class="mb-2 text-2xl font-semibold leading-tight text-on-surface">{entry.title}</h3>
							<p class="mb-5 text-sm font-medium text-secondary md:text-base">{entry.subtitle}</p>
							<p class="text-sm leading-7 text-on-surface-variant/80 md:text-base">{entry.body}</p>
						</HudFrame>
					</article>
				))}

				<div class="timeline-end-spacer min-w-48 shrink-0 snap-end md:min-w-80" aria-hidden="true"></div>
			</div>

			<div class="timeline-pagination" aria-label="Experience timeline carousel navigation">
				{entries.map((entry, index) => (
					<button
						class="timeline-dot"
						type="button"
						data-timeline-dot
						data-timeline-index={index}
						aria-label={`Show timeline item ${index + 1}: ${entry.title}`}
						aria-current={index === 0 ? "true" : "false"}
					>
						<span>{String(index + 1).padStart(2, "0")}</span>
					</button>
				))}
			</div>
		</div>
	</div>
</section>

<style>
	.timeline-shell {
		min-height: 31rem;
		margin-inline: calc(var(--space-margin-mobile) * -1);
	}

	.timeline-viewport {
		isolation: isolate;
	}

	.timeline-scroll {
		-ms-overflow-style: none;
		scrollbar-width: none;
		scroll-padding-inline: 6rem;
	}

	.timeline-scroll::-webkit-scrollbar {
		display: none;
	}

	.timeline-track {
		position: absolute;
		left: 6rem;
		right: 6rem;
		top: 8rem;
		height: 2px;
		background:
			linear-gradient(90deg, rgb(255 255 255 / 0.08), rgb(255 255 255 / 0.2), rgb(255 255 255 / 0.08)),
			repeating-linear-gradient(90deg, transparent 0 5rem, rgb(208 188 255 / 0.28) 5rem 5.125rem);
		box-shadow: 0 0 22px rgb(139 92 246 / 0.24);
	}

	.timeline-track span {
		display: block;
		width: 100%;
		height: 100%;
		background: linear-gradient(90deg, #8b5cf6, #d0bcff);
		box-shadow: 0 0 26px rgb(208 188 255 / 0.7);
		transform: scaleX(var(--timeline-progress, 0));
		transform-origin: left center;
		transition: transform 120ms ease-out;
	}

	.timeline-node {
		position: absolute;
		left: 1.5rem;
		top: 0;
		z-index: 20;
		display: grid;
		height: 3.25rem;
		width: 3.25rem;
		place-items: center;
		border: 1px solid rgb(208 188 255 / 0.7);
		border-radius: 9999px;
		background:
			radial-gradient(circle, rgb(208 188 255 / 0.35), rgb(79 49 156 / 0.18) 58%, rgb(10 10 11 / 0.72)),
			rgb(19 19 20 / 0.86);
		box-shadow:
			0 0 0 8px rgb(139 92 246 / 0.08),
			0 0 24px rgb(208 188 255 / 0.45);
		color: #e9ddff;
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-decoration: none;
		transition:
			border-color 180ms ease,
			box-shadow 180ms ease,
			transform 180ms ease;
	}

	.timeline-node:hover,
	.timeline-node:focus-visible {
		border-color: rgb(255 255 255 / 0.9);
		box-shadow:
			0 0 0 8px rgb(139 92 246 / 0.12),
			0 0 34px rgb(208 188 255 / 0.62);
		transform: scale(1.04);
	}

	.timeline-node:focus-visible {
		outline: 2px solid rgb(208 188 255 / 0.8);
		outline-offset: 0.35rem;
	}

	.timeline-node::before,
	.timeline-node::after {
		position: absolute;
		content: "";
		border-radius: 9999px;
	}

	.timeline-node::before {
		inset: 0.65rem;
		border: 1px dashed rgb(255 255 255 / 0.28);
	}

	.timeline-node::after {
		left: 50%;
		top: 100%;
		height: 2.5rem;
		width: 1px;
		background: linear-gradient(rgb(208 188 255 / 0.8), transparent);
	}

	.timeline-station {
		--station-x: 1.5rem;
		--station-y: 4.6rem;
		--station-rotation: 0deg;
		position: absolute;
		left: 0;
		top: 0;
		z-index: 30;
		display: grid;
		height: 4.8rem;
		width: 4.8rem;
		place-items: center;
		pointer-events: none;
		filter: drop-shadow(0 0 12px rgb(208 188 255 / 0.68));
		transform: translate3d(var(--station-x), var(--station-y), 0) rotate(var(--station-tilt, -2deg));
		transition: transform 140ms ease-out;
	}

	.endurance-ring {
		position: relative;
		height: 3.7rem;
		width: 3.7rem;
		border: 1px solid rgb(233 221 255 / 0.88);
		border-radius: 9999px;
		background:
			radial-gradient(circle, transparent 0 34%, rgb(10 10 11 / 0.94) 35% 49%, transparent 50%),
			conic-gradient(
				from 0deg,
				#f5efff 0deg 13deg,
				transparent 13deg 33deg,
				#9b86d7 33deg 48deg,
				transparent 48deg 78deg,
				#d0bcff 78deg 94deg,
				transparent 94deg 123deg,
				#7c5ad6 123deg 140deg,
				transparent 140deg 171deg,
				#f5efff 171deg 187deg,
				transparent 187deg 214deg,
				#9b86d7 214deg 231deg,
				transparent 231deg 263deg,
				#d0bcff 263deg 280deg,
				transparent 280deg 312deg,
				#7c5ad6 312deg 329deg,
				transparent 329deg 360deg
			);
		box-shadow:
			inset 0 0 16px rgb(255 255 255 / 0.2),
			0 0 24px rgb(139 92 246 / 0.36);
		transform: rotate(var(--station-rotation));
	}

	.endurance-ring::before,
	.endurance-ring::after {
		position: absolute;
		content: "";
		inset: 0.55rem;
		border-radius: inherit;
		border: 1px solid rgb(208 188 255 / 0.4);
	}

	.endurance-ring::after {
		inset: 1.35rem;
		border-color: rgb(255 255 255 / 0.42);
		background: radial-gradient(circle, rgb(255 255 255 / 0.85), rgb(208 188 255 / 0.48) 34%, transparent 36%);
	}

	.endurance-hub {
		position: absolute;
		left: 50%;
		top: 50%;
		z-index: 2;
		height: 0.42rem;
		width: 1.35rem;
		border-radius: 9999px;
		background: linear-gradient(90deg, transparent, rgb(255 255 255 / 0.95), transparent);
		transform: translate(-50%, -50%) rotate(18deg);
	}

	.endurance-dock {
		position: absolute;
		z-index: 3;
		height: 0.48rem;
		width: 0.9rem;
		border: 1px solid rgb(255 255 255 / 0.78);
		border-radius: 0.12rem;
		background: linear-gradient(135deg, #f4efff, #7e61d7);
		box-shadow: 0 0 10px rgb(208 188 255 / 0.4);
	}

	.endurance-dock-top {
		left: 50%;
		top: -0.2rem;
		transform: translateX(-50%) rotate(90deg);
	}

	.endurance-dock-right {
		right: -0.2rem;
		top: 50%;
		transform: translateY(-50%);
	}

	.endurance-dock-bottom {
		bottom: -0.2rem;
		left: 50%;
		transform: translateX(-50%) rotate(90deg);
	}

	.endurance-dock-left {
		left: -0.2rem;
		top: 50%;
		transform: translateY(-50%);
	}

	.timeline-pagination {
		position: relative;
		z-index: 20;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		padding: 0 1.5rem 2rem;
	}

	.timeline-pagination::before {
		position: absolute;
		left: 50%;
		top: 0.58rem;
		z-index: -1;
		height: 1px;
		width: min(34rem, calc(100% - 3rem));
		content: "";
		background: linear-gradient(90deg, transparent, rgb(208 188 255 / 0.32), transparent);
		box-shadow: 0 0 18px rgb(139 92 246 / 0.2);
		transform: translateX(-50%);
	}

	.timeline-dot {
		position: relative;
		display: grid;
		height: 1.2rem;
		width: 1.2rem;
		place-items: center;
		border: 1px solid rgb(208 188 255 / 0.38);
		border-radius: 9999px;
		background:
			radial-gradient(circle, rgb(208 188 255 / 0.34), rgb(79 49 156 / 0.14) 56%, rgb(10 10 11 / 0.82)),
			rgb(19 19 20 / 0.84);
		box-shadow:
			0 0 0 4px rgb(139 92 246 / 0.06),
			0 0 14px rgb(139 92 246 / 0.18);
		color: transparent;
		cursor: pointer;
		transition:
			width 180ms ease,
			border-color 180ms ease,
			background 180ms ease,
			box-shadow 180ms ease,
			transform 180ms ease;
	}

	.timeline-dot span {
		font-size: 0;
	}

	.timeline-dot:hover,
	.timeline-dot:focus-visible,
	.timeline-dot[aria-current="true"] {
		border-color: rgb(245 239 255 / 0.9);
		background:
			linear-gradient(90deg, rgb(139 92 246 / 0.95), rgb(208 188 255 / 0.95)),
			rgb(19 19 20 / 0.92);
		box-shadow:
			0 0 0 5px rgb(139 92 246 / 0.12),
			0 0 24px rgb(208 188 255 / 0.52);
		transform: translateY(-1px);
	}

	.timeline-dot[aria-current="true"] {
		width: 2.9rem;
	}

	.timeline-dot:focus-visible {
		outline: 2px solid rgb(208 188 255 / 0.82);
		outline-offset: 0.35rem;
	}

	@media (max-width: 767px) {
		.timeline-shell {
			min-height: 29rem;
			margin-inline: calc(var(--space-margin-mobile) * -1);
		}

		.timeline-track {
			left: 1.5rem;
			right: 1.5rem;
			top: 7.75rem;
		}

		.timeline-scroll {
			scroll-padding-inline: 1.5rem;
		}
	}

	@media (min-width: 768px) {
		.timeline-shell {
			margin-inline: calc(var(--space-margin-desktop) * -1);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.timeline-track span,
		.timeline-station,
		.timeline-card :global(*) {
			transition: none !important;
		}
	}
</style>

<script>
	const timelines = document.querySelectorAll("[data-timeline-scroll]");

	timelines.forEach((timeline) => {
		const viewport = timeline.closest("[data-timeline-viewport]");
		const ship = viewport?.querySelector("[data-timeline-ship]");
		const progressBar = viewport?.querySelector("[data-timeline-progress]");
		const cards = Array.from(timeline.querySelectorAll("[data-timeline-card]")).filter(
			(card): card is HTMLElement => card instanceof HTMLElement,
		);
		const dots = Array.from(viewport?.querySelectorAll("[data-timeline-dot]") ?? []).filter(
			(dot): dot is HTMLButtonElement => dot instanceof HTMLButtonElement,
		);

		if (!(ship instanceof HTMLElement) || !(progressBar instanceof HTMLElement)) {
			return;
		}

		const clamp = (value: number, min: number, max: number) => Math.min(Math.max(value, min), max);
		let frame = 0;
		let maxScroll = 0;
		let viewportWidth = 0;
		let shipHalfWidth = 0;
		let shipHalfHeight = 0;
		let cardMetrics: Array<{
			card: HTMLElement;
			centerX: number;
			nodeX: number;
			nodeY: number;
		}> = [];

		const measureTimeline = () => {
			maxScroll = Math.max(timeline.scrollWidth - timeline.clientWidth, 0);
			viewportWidth = timeline.clientWidth;
			shipHalfWidth = ship.offsetWidth / 2;
			shipHalfHeight = ship.offsetHeight / 2;
			cardMetrics = cards.map((card) => {
				const anchor = card.querySelector("[data-timeline-anchor]");
				const anchorElement = anchor instanceof HTMLElement ? anchor : null;

				return {
					card,
					centerX: card.offsetLeft + card.offsetWidth / 2,
					nodeX: card.offsetLeft + (anchorElement?.offsetLeft ?? 0) + (anchorElement?.offsetWidth ?? 0) / 2,
					nodeY: card.offsetTop + (anchorElement?.offsetTop ?? 0) + (anchorElement?.offsetHeight ?? 0) / 2,
				};
			});
		};

		const getCardScrollTarget = (card: HTMLElement) => {
			const metric = cardMetrics.find((item) => item.card === card);
			const target = (metric?.centerX ?? card.offsetLeft + card.offsetWidth / 2) - viewportWidth / 2;
			return clamp(target, 0, maxScroll);
		};

		const getActiveCard = () => {
			if (cardMetrics.length === 0) {
				return null;
			}

			const viewportCenter = timeline.scrollLeft + viewportWidth / 2;

			return cardMetrics.reduce((closest, metric) => (
				Math.abs(metric.centerX - viewportCenter) < Math.abs(closest.centerX - viewportCenter) ? metric : closest
			), cardMetrics[0]);
		};

		const updateTimeline = () => {
			frame = 0;
			const progress = maxScroll > 0 ? timeline.scrollLeft / maxScroll : 0;
			const activeMetric = getActiveCard();

			if (!activeMetric) {
				return;
			}

			const x = activeMetric.nodeX - timeline.scrollLeft - shipHalfWidth;
			const y = activeMetric.nodeY - shipHalfHeight;
			const tilt = -10 + progress * 20;
			const rotation = progress * 540;

			ship.style.setProperty("--station-x", `${x}px`);
			ship.style.setProperty("--station-y", `${y}px`);
			ship.style.setProperty("--station-tilt", `${tilt}deg`);
			ship.style.setProperty("--station-rotation", `${rotation}deg`);
			progressBar.style.setProperty("--timeline-progress", String(progress));

			const activeIndex = cards.indexOf(activeMetric.card);

			dots.forEach((dot, index) => {
				dot.setAttribute("aria-current", index === activeIndex ? "true" : "false");
			});
		};

		const requestTimelineUpdate = () => {
			if (frame !== 0) {
				return;
			}

			frame = window.requestAnimationFrame(updateTimeline);
		};

		const refreshTimeline = () => {
			measureTimeline();
			requestTimelineUpdate();
		};

		timeline.addEventListener(
			"wheel",
			(event) => {
				const wheelEvent = event as WheelEvent;

				if (Math.abs(wheelEvent.deltaY) <= Math.abs(wheelEvent.deltaX)) {
					return;
				}

				wheelEvent.preventDefault();
				timeline.scrollBy({ left: wheelEvent.deltaY, behavior: "smooth" });
			},
			{ passive: false },
		);

		cards.forEach((card) => {
			const anchor = card.querySelector("[data-timeline-anchor]");

			if (!(anchor instanceof HTMLAnchorElement)) {
				return;
			}

			anchor.addEventListener("click", (event) => {
				event.preventDefault();

				timeline.scrollTo({ left: getCardScrollTarget(card), behavior: "smooth" });
				history.replaceState(null, "", anchor.hash);
				window.setTimeout(requestTimelineUpdate, 240);
			});
		});

		dots.forEach((dot) => {
			dot.addEventListener("click", () => {
				const index = Number(dot.dataset.timelineIndex);
				const card = cards[index];

				if (!card) {
					return;
				}

				timeline.scrollTo({ left: getCardScrollTarget(card), behavior: "smooth" });
				history.replaceState(null, "", `#${card.id}`);
				window.setTimeout(requestTimelineUpdate, 240);
			});
		});

		timeline.addEventListener("scroll", requestTimelineUpdate, { passive: true });
		window.addEventListener("resize", refreshTimeline);
		refreshTimeline();
	});
</script>
