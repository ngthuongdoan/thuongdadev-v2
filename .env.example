# GitHub OAuth credentials for Decap CMS
# Obtain these from https://github.com/settings/developers.  The CMS requests only
# `public_repo` and `read:user` scopes to minimise permissions.  Keep your
# secrets safe – never commit the real values to version control.

GH_CLIENT_ID=your_github_oauth_client_id
GH_CLIENT_SECRET=your_github_oauth_client_secret

# Base URL of your deployment (used for OAuth redirects)
ORIGIN=https://thuongda.dev

# Comma‑separated GitHub usernames allowed to access /admin
GH_ALLOWED_USERS=ngthuongdoan